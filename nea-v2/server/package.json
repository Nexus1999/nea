{
  "name": "neas-v2-server",
  "version": "1.0.0",
  "description": "NEAS Express Backend with Neon DB",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
